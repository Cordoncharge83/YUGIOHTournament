{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Yu-Gi-Oh Tournament Manager",
  "version": "0.1.0",
  "identifier": "com.yugioh.tournamentmanager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build:release",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Yu-Gi-Oh Tournament Manager",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../../backend/dist/yugioh-backend": "backend/yugioh-backend"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
